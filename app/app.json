{
  "expo": {
    "name": "Breadcrumbie",
    "slug": "breadcrumbie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "breadcrumbie",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FAFAF8",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.breadcrumbie.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5A623"
      },
      "package": "com.breadcrumbie.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
